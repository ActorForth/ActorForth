{
    "comments": { "lineComment": "#" },
    "brackets": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"]
    ],
    "autoClosingPairs": [
        { "open": "\"", "close": "\"" },
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "{", "close": "}" }
    ],
    "surroundingPairs": [
        { "open": "\"", "close": "\"" }
    ],
    "wordPattern": "[A-Za-z_?!\\-][A-Za-z0-9_?!\\-]*"
}
