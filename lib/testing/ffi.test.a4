# FFI tests — ported subset of test/af_ffi_tests.erl.
# Omits tests that depend on node / system_time / real process state.

"ffi" group

"call erlang:abs/1" test :
    nil -5 cons abs erlang erlang-apply
    5 assert-eq
;

"call erlang:max/2" test :
    nil 10 cons 20 cons max erlang erlang-apply
    20 assert-eq
;

"call erlang:min/2" test :
    nil 100 cons 3 cons min erlang erlang-apply
    3 assert-eq
;

"call lists:sort/1" test :
    nil nil 3 cons 1 cons 2 cons cons sort lists erlang-apply
    dup length 3 assert-eq
    head 1 assert-eq
;

"call nonexistent function raises ffi_error" test-raises ffi_error :
    nil nosuchfunc nosuchmod erlang-apply
;

"erlang-call with bad function raises" test-raises ffi_error :
    nosuchfunc nosuchmod 0 erlang-call
;

.
