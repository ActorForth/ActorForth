# Float operations — ported from test/af_type_float_tests.erl.
# Tests that exercise the Atom->Float op path stay in Erlang.

float_ops group

"float literal auto-detection" test :
    3.14 3.14 assert-eq
;

# --- Mixed arithmetic: Int on TOS, Float below ---

"float + int (Int on TOS)" test :
    2.5 3 + 5.5 assert-eq
;

"float * int (Int on TOS)" test :
    2.5 3 * 7.5 assert-eq
;

"float - int (Int on TOS)" test :
    10.0 3 - 7.0 assert-eq
;

"float / int (Int on TOS)" test :
    10.0 2 / 5.0 assert-eq
;

# --- Mixed arithmetic: Float on TOS, Int below ---

"int + float (Float on TOS)" test :
    3 2.5 + 5.5 assert-eq
;

"int * float (Float on TOS)" test :
    3 2.5 * 7.5 assert-eq
;

"int - float (Float on TOS)" test :
    10 3.0 - 7.0 assert-eq
;

"int / float (Float on TOS)" test :
    10 2.0 / 5.0 assert-eq
;

.
