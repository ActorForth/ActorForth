# Stdlib tests — ported from test/af_stdlib_tests.erl (subset).
# Loads priv/stdlib.a4 to pick up negate, square, cube, double, even?, etc.

"../../priv/stdlib.a4" load

"stdlib" group

# --- negate ---

"negate positive" test :
    5 negate -5 assert-eq
;

"negate negative" test :
    -3 negate 3 assert-eq
;

"negate zero" test :
    0 negate 0 assert-eq
;

# --- double ---

"double positive" test :
    5 double 10 assert-eq
;

"double zero" test :
    0 double 0 assert-eq
;

# --- square ---

"square positive" test :
    4 square 16 assert-eq
;

"square negative" test :
    -3 square 9 assert-eq
;

# --- cube ---

"cube positive" test :
    3 cube 27 assert-eq
;

# --- mod ---

"mod computes remainder" test :
    10 3 mod 1 assert-eq
;

"mod with exact division" test :
    12 4 mod 0 assert-eq
;

"mod by zero raises" test-raises division_by_zero :
    10 0 mod
;

# --- Sign predicates ---

"positive? true for positive" test :
    5 positive? assert
;

"positive? false for zero" test :
    0 positive? not assert
;

"negative? true for negative" test :
    -5 negative? assert
;

"zero? true for zero" test :
    0 zero? assert
;

# --- inc / dec ---

"inc adds 1" test :
    5 inc 6 assert-eq
;

"dec subtracts 1" test :
    5 dec 4 assert-eq
;

# --- clamp ---

"clamp below keeps low bound" test :
    -5 0 10 clamp 0 assert-eq
;

"clamp above keeps high bound" test :
    20 0 10 clamp 10 assert-eq
;

"clamp in range is unchanged" test :
    5 0 10 clamp 5 assert-eq
;

# --- Boolean helpers ---

"xor of differing is true" test :
    True False xor assert
;

"xor of same is false" test :
    True True xor not assert
;

# --- List reductions ---

"sum of empty is 0" test :
    [ ] sum 0 assert-eq
;

"sum of 1,2,3 is 6" test :
    [ 1 2 3 ] sum 6 assert-eq
;

"product of 1,2,3,4 is 24" test :
    [ 1 2 3 4 ] product 24 assert-eq
;

.
