{erl_opts, [debug_info]}.
{eunit_opts, [verbose]}.
{eunit_tests, [{dir, "test"}]}.
{cover_enabled, true}.
{cover_export_enabled, true}.
{cover_excl_mods, [af_repl]}.
{ct_opts, [{dir, "test"}]}.
{deps, [
    {erlang_python, "1.8.1"}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]}
    ]}
]}.

