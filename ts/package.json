{
  "name": "actorforth",
  "version": "0.1.0",
  "description": "ActorForth — concatenative, stack-based, strongly typed language targeting TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "repl": "node dist/repl.js",
    "browser": "esbuild src/browser.ts --bundle --outfile=dist/actorforth.js --format=iife --global-name=ActorForth"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
