# fib.a4 - the first ever real program for ActorForth!

: fib Int -> Int ;
    : 0 -> 0 ;
    : 1 -> 1 ;
    : Int -> Int ; # This type spec is optional since it matches the master spec.
        dup
        1 int -
        fib
        swap
        2 int -
        fib
        +.

# : f Int -> Int ;
#     dup print fib.

# 12 int f "fib = " print print
