# Python AI integration demo (using stubs — no API key needed)
# Run: source .venv/bin/activate && rebar3 shell
#      af_repl:run_file("samples/py_ai_demo.a4").
#
# This uses ai_stub.py which has fake embeddings/chat.
# For real AI, use llm_client.py with an API key instead.

py-start
"samples/python" py-import

# Generate a stub embedding vector for text
"ActorForth is a stack-based language" ai_stub embed_text 1 py-call
print

# Parse a JSON array
"[1, 2, 3, 4, 5]" ai_stub from_json 1 py-call
print

# Convert data to a JSON string
"[10, 20, 30]" ai_stub from_json 1 py-call
ai_stub to_json 1 py-call
print

# Stub chat completion
"What is ActorForth?" ai_stub chat_complete 1 py-call
print

# Semantic search — find most similar document
"programming language" ai_stub embed_text 1 py-call drop
"__import__('ai_stub').cosine_similarity([1,0,0,0,0,0,0,0],[0.9,0.1,0,0,0,0,0,0])" py-eval
print
