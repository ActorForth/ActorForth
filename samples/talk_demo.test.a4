# Talk-demo showcase — run with:
#   rebar3 shell --eval 'af_test_runner:run(["samples/talk_demo.test.a4"], [{render,dashboard}]).'
#
# Exercises the test DSL end-to-end:
#   - nested groups
#   - group-serial for tests sharing external state
#   - skip-test with a reason
#   - max-depth auto-assert
#   - test-raises negative test
#   - one deliberate failure to show the diagnostic engine catching
#     an extra-atom fall-through
#
# Every test runs in its own BEAM actor; pids are visible in the
# streaming / dashboard view.

talk_demo group

    # --- arithmetic: pure, runs maximally parallel ---
    arithmetic group
        8 max-depth

        "add" test :
            2 3 + 5 assert-eq
        ;

        "multiply" test :
            4 5 * 20 assert-eq
        ;

        "divide by zero raises" test-raises division_by_zero :
            10 0 /
        ;

        "demo a skipped case" "pending stdlib port" skip-test :
            42 answer-of-everything assert-eq
        ;
    .

    # --- lists: shows deeper stack, cons chain ---
    lists group

        "cons chain length" test :
            nil 1 cons 2 cons 3 cons
            length 3 assert-eq
        ;

        "reverse a list" test :
            nil 1 cons 2 cons 3 cons reverse
            head 1 assert-eq
        ;

        # Deliberate fail: bogus-word falls through to {Atom, _}
        # and sits on the stack under the expected Int — the
        # diagnostic engine catches "extra_atom" and reports it.
        "DELIBERATELY BROKEN to demo diagnostics" test :
            2 3 + bogus-word-typo
            5 assert-eq
        ;
    .

    # --- serial group: these tests share ordering semantics ---
    timing group-serial

        "timed step 1" test :
            1 1 + 2 assert-eq
        ;

        "timed step 2" test :
            3 3 + 6 assert-eq
        ;

        "timed step 3" test :
            5 5 + 10 assert-eq
        ;
    .

.
